module SimpleCov
  module ExitCodes
    # Fails when any configured group falls below its minimum coverage
    # threshold for any criterion.
    class MinimumCoverageByGroupCheck
      @result: untyped

      @minimum_coverage_by_group: untyped

      @violations: untyped

      def initialize: (untyped result, untyped minimum_coverage_by_group) -> void

      def failing?: () -> untyped

      def report: () -> untyped

      def exit_code: () -> untyped

      private

      def violations: () -> untyped
    end
  end
end
