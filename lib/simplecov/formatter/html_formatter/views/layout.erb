<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Code coverage for <%= SimpleCov.project_name %></title>
    <script src='<%= assets_path('application.js') %>' type='text/javascript'></script>
    <link href='<%= assets_path('application.css') %>' media='screen, projection, print' rel='stylesheet' type='text/css' />
    <link rel="icon" type="image/png" href="<%= assets_path("favicon_#{coverage_css_class(result.source_files.covered_percent)}.png") %>" />
    <script type="text/javascript">
      (function() {
        var pref = localStorage.getItem('simplecov-dark-mode');
        if (pref === 'dark') {
          document.documentElement.classList.add('dark-mode');
        } else if (pref === 'light') {
          document.documentElement.classList.add('light-mode');
        }
      })();
    </script>
  </head>

  <body<%= ' data-branch-coverage=true' if branch_coverage? %>>
    <div id="loading" data-total-files="<%= result.source_files.count %>" style="display: none">
      <div id="loading-inner">
        <div id="loading-bar-track">
          <div id="loading-bar-fill"></div>
        </div>
        <div id="loading-text">Loading 0%</div>
      </div>
    </div>
    <script type="text/javascript">
      (function() {
        var loading = document.getElementById('loading');
        var total = parseInt(loading.getAttribute('data-total-files'), 10) || 1;
        var fill = document.getElementById('loading-bar-fill');
        var text = document.getElementById('loading-text');
        var showTimeout = setTimeout(function() { loading.style.display = ''; }, 250);
        var timer = setInterval(function() {
          var parsed = document.querySelectorAll('template[id^="tmpl-"]').length;
          var pct = Math.min(Math.round((parsed / total) * 100), 99);
          fill.style.width = pct + '%';
          text.textContent = 'Loading ' + pct + '%';
        }, 50);
        window._simplecovLoadingTimer = timer;
        window._simplecovShowTimeout = showTimeout;
      })();
    </script>
    <div id="wrapper" class="hide">
      <div class="tab-bar">
        <ul class="group_tabs" role="tablist"></ul>
        <button id="dark-mode-toggle" aria-label="Toggle dark mode"></button>
      </div>

      <div id="content">
        <%= formatted_file_list("All Files", result.source_files) %>
<%- result.groups.each do |name, files| -%>
        <%= formatted_file_list(name, files) %>
<%- end -%>
      </div>

      <div id="footer">
        Generated <%= timeago(Time.now) %>
        by <a href="https://github.com/simplecov-ruby/simplecov">simplecov</a> v<%= SimpleCov::VERSION %>
        and <a href="https://github.com/simplecov-ruby/simplecov-html">simplecov-html</a> v<%= SimpleCov::Formatter::HTMLFormatter::VERSION %>
        using <%= result.command_name %>
      </div>

      <div class="source_files">
<%- result.source_files.each do |source_file| -%>
        <template id="tmpl-<%= id(source_file) %>">
          <%= formatted_source_file(source_file) %>
        </template>
<%- end -%>
      </div>
    </div>

    <dialog id="source-dialog" class="source-dialog">
      <div class="source-dialog__header">
        <div class="source-dialog__title" id="source-dialog-title"></div>
        <div class="source-legend">
          <span class="source-legend__item"><span class="source-legend__swatch source-legend__swatch--covered"></span>Covered</span>
          <span class="source-legend__item"><span class="source-legend__swatch source-legend__swatch--skipped"></span>Skipped</span>
          <span class="source-legend__item"><span class="source-legend__swatch source-legend__swatch--missed"></span>Missed line</span>
<%- if branch_coverage? -%>
          <span class="source-legend__item"><span class="source-legend__swatch source-legend__swatch--missed-branch"></span>Missed branch</span>
<%- end -%>
<%- if method_coverage? -%>
          <span class="source-legend__item"><span class="source-legend__swatch source-legend__swatch--missed-method"></span>Missed method</span>
<%- end -%>
        </div>
        <button class="source-dialog__close" aria-label="Close" title="Close">&times;</button>
      </div>
      <div class="source-dialog__body" id="source-dialog-body" tabindex="0"></div>
    </dialog>
  </body>
</html>
